<?xml version="1.0" encoding="UTF-8"?>
<!--
  svg_llm.inx — minimal shell.
  All UI is provided by the GTK dialog in svg_llm_dialog.py.
  No <param> elements; Inkscape launches the script directly.
-->
<inkscape-extension xmlns="http://www.inkscape.org/namespace/inkscape/extension">
    <name>AI SVG Generator</name>
    <id>org.inkscape.ai.svg.generator</id>
    <effect needs-live-preview="false" implements-custom-gui="true">
        <object-type>all</object-type>
        <effects-menu>
            <submenu name="Generate"/>
        </effects-menu>
    </effect>
    <script>
        <command location="inx" interpreter="python">svg_llm.py</command>
    </script>
</inkscape-extension>
